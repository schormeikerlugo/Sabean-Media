---
const stats = [
  { value: 30, suffix: "+", label: "Years in Media" },
  { value: 20, suffix: "+", label: "Global Brands Built" },
  { value: 4, suffix: "", label: "Industry Veterans" },
];
---

<section class="relative border-t border-b border-[rgba(212,175,55,0.12)] bg-ink py-16 md:py-20">
  <div class="mx-auto grid max-w-[1600px] grid-cols-1 items-start gap-10 px-6 md:grid-cols-12 md:px-10">
    <div class="grid grid-cols-3 gap-4 md:col-span-7 md:gap-10 text-center md:text-left">
      {stats.map((s, i) => (
        <div class={`reveal reveal-delay-${i + 1}`}>
          <div class="flex items-start justify-center font-display leading-none text-gold-gradient text-[clamp(3.5rem,9vw,7rem)] font-light md:justify-start">
            <span data-countup={s.value}>0</span>
            {s.suffix && <span class="ml-1 text-[0.6em]">{s.suffix}</span>}
          </div>
          <p class="mt-3 text-[0.7rem] uppercase tracking-[0.28em] text-bone-muted leading-[1.7]">
            {s.label}
          </p>
        </div>
      ))}
    </div>

    <div class="md:col-span-5 reveal reveal-delay-4 md:pl-8 md:border-l md:border-[rgba(212,175,55,0.12)] text-center md:text-left">
      <div class="flex items-center justify-center gap-3 md:justify-start">
        <span class="grid h-6 w-6 place-items-center rounded-full border border-[rgba(212,175,55,0.35)]">
          <svg viewBox="0 0 24 24" class="h-2.5 w-2.5 text-gold-300" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 12 L12 5 L22 12 L12 19 Z"/></svg>
        </span>
        <span class="font-display text-lg text-gold-gradient">sabean<sup class="text-[0.5em] ml-0.5">®</sup></span>
      </div>
      <p class="mx-auto md:mx-0 mt-4 max-w-md text-[1.05rem] leading-[1.6] text-bone/80">
        Every engagement we take on is engineered for <em class="not-italic text-gold-200">360° growth</em>, multi-vertical revenue and long-term audience monetization.
      </p>
    </div>
  </div>
</section>
