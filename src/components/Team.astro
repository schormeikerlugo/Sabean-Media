---
import { team } from "~/data/team";
---

<section id="team" class="relative overflow-hidden bg-ink py-28 md:py-36">
  <div class="mx-auto max-w-[1600px] px-6 md:px-10">
    <header class="mb-14 grid grid-cols-1 items-end gap-8 md:grid-cols-12 reveal text-center md:text-left">
      <div class="md:col-span-6">
        <div class="flex items-center justify-center gap-3 text-[0.7rem] uppercase tracking-[0.32em] text-bone-muted md:justify-start">
          <span class="text-bone">What the team brings.</span>
          <span class="text-gold-400">(*)</span>
        </div>
        <h2 class="mt-6 font-display text-[clamp(2.8rem,5.2vw,4.5rem)] font-light leading-[0.95]">
          Operators who have
          <span class="block italic text-shine">built the rooms.</span>
        </h2>
      </div>
      <div class="md:col-span-6 flex flex-wrap justify-center gap-2 md:justify-end">
        {team.map((m) => (
          <span class="rounded-full border border-[rgba(212,175,55,0.2)] bg-black/40 px-3 py-1.5 text-[0.64rem] uppercase tracking-[0.22em] text-bone-muted">
            {m.name.split(" ")[0]} · {m.shortRole}
          </span>
        ))}
      </div>
    </header>

    <div
      class="grid grid-cols-1 gap-8 md:grid-cols-12 md:gap-10"
      data-team-root
    >
      <div class="md:col-span-4 relative">
        <div class="sticky top-24 mx-auto w-full max-w-[340px]">
          <div class="relative overflow-hidden rounded-2xl border border-[rgba(212,175,55,0.18)] bg-[#0a0a0a] aspect-[4/5]">
            {team.map((m, i) => (
              <img
                src={m.image}
                alt={`Portrait of ${m.name}, ${m.shortRole}`}
                loading={i === 0 ? "eager" : "lazy"}
                decoding="async"
                data-team-image={m.id}
                class={`absolute inset-0 h-full w-full object-cover grayscale transition-opacity duration-700 ${i === 0 ? "opacity-100" : "opacity-0"}`}
              />
            ))}
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/55 via-transparent to-transparent"></div>
            <div class="absolute left-4 top-4 flex items-center gap-2 rounded-full bg-black/60 px-3 py-1.5 text-[0.6rem] uppercase tracking-[0.28em] text-gold-300 backdrop-blur-md">
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-gold-300 pulse-glow"></span>
              <span data-team-role>{team[0].shortRole}</span>
            </div>
            <div class="absolute bottom-4 left-4">
              <p class="font-display text-3xl font-light italic text-bone" data-team-name>
                {team[0].name}
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="md:col-span-8 md:pl-8 md:border-l md:border-[rgba(212,175,55,0.12)]">
        <ul>
          {team.map((m, i) => (
            <li>
              <button
                type="button"
                data-team-btn={m.id}
                data-active={i === 0 ? "true" : "false"}
                class="group w-full rounded-lg border-b border-[rgba(212,175,55,0.12)] px-5 py-6 text-center transition-colors data-[active=true]:bg-[rgba(212,175,55,0.04)] hover:bg-[rgba(212,175,55,0.025)] md:px-7 md:text-left"
              >
                <div class="grid grid-cols-12 items-center gap-3">
                  <span class="col-span-2 text-[0.68rem] uppercase tracking-[0.32em] text-bone-muted md:col-span-1">
                    (0{i + 1})
                  </span>
                  <span class="col-span-8 font-display text-2xl font-light text-bone transition-colors group-hover:text-gold-gradient group-data-[active=true]:text-gold-gradient md:col-span-8 md:text-3xl">
                    {m.name}
                  </span>
                  <span class="col-span-2 flex justify-end self-start md:col-span-3">
                    <span class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-[rgba(212,175,55,0.25)] bg-black/30 text-gold-300 transition-all duration-300 group-hover:border-gold-300/60 group-data-[active=true]:border-gold-300 group-data-[active=true]:bg-[rgba(212,175,55,0.08)] group-data-[active=true]:text-gold-300">
                      <svg viewBox="0 0 20 20" class="h-3.5 w-3.5 transition-transform duration-300 group-data-[active=true]:rotate-90" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10h12M10 4l6 6-6 6"/></svg>
                    </span>
                  </span>
                </div>
                <div
                  class="grid overflow-hidden transition-[grid-template-rows] duration-500 ease-out grid-rows-[0fr] group-data-[active=true]:grid-rows-[1fr]"
                >
                  <div class="overflow-hidden">
                    <div class="pt-6 md:ml-[calc(8.33%+0.75rem)] md:pr-8">
                      <p class="text-[0.7rem] uppercase tracking-[0.24em] text-gold-400">{m.role}</p>
                      <p class="mt-4 text-[0.98rem] leading-relaxed text-bone/80">
                        {m.bio}
                      </p>
                      <div class="mt-5 flex flex-wrap gap-2">
                        {m.focus.map((f) => (
                          <span class="rounded-full border border-[rgba(212,175,55,0.18)] px-3 py-1 text-[0.62rem] uppercase tracking-[0.2em] text-bone-muted">{f}</span>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              </button>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-team-root]");
    if (!root) return;
    const btns = root.querySelectorAll("[data-team-btn]");
    const imgs = root.querySelectorAll("[data-team-image]");
    const nameEl = root.querySelector("[data-team-name]");
    const roleEl = root.querySelector("[data-team-role]");

    btns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-team-btn");
        btns.forEach((b) => b.setAttribute("data-active", b === btn ? "true" : "false"));
        imgs.forEach((img) => {
          const match = img.getAttribute("data-team-image") === id;
          img.style.opacity = match ? "1" : "0";
          if (match && nameEl && roleEl) {
            const active = btn.querySelector("span.font-display")?.textContent || "";
            nameEl.textContent = active;
            const role = btn.querySelector("p.text-gold-400")?.textContent || "";
            const short = role.split(" — ")[0]?.trim();
            roleEl.textContent = short || roleEl.textContent;
          }
        });
      });
    });
  })();
</script>
