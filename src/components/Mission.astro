---

---

<section id="mission" class="relative overflow-hidden bg-ink pt-28 pb-16 md:pt-36 md:pb-20">
  <div class="mx-auto max-w-[1600px] px-6 md:px-10">
    <header
      class="mb-20 grid grid-cols-1 items-start gap-10 md:mb-24 md:grid-cols-12"
    >
      <div class="md:col-span-3 reveal">
        <div
          class="flex items-center justify-center gap-3 text-[0.7rem] uppercase tracking-[0.32em] text-bone-muted md:justify-start"
        >
          <span class="text-bone">Mission.</span>
          <span class="text-gold-400">(*)</span>
        </div>
      </div>
      <div
        class="md:col-span-9 md:pl-8 md:border-l md:border-[rgba(212,175,55,0.12)] reveal reveal-delay-1 text-center md:text-left"
      >
        <p
          class="font-display text-[clamp(1.6rem,3.2vw,2.6rem)] font-light leading-[1.25] text-balance"
        >
          Our mission is to leverage our significant network and expertise to
          help high-end talent and brands build their own content, entertainment
          and media-centric platforms — with a focus on
          <span class="text-shine">360° growth</span>,
          <span class="text-shine">multi-vertical revenue</span> and
          <span class="text-shine">audience monetization.</span>
        </p>
      </div>
    </header>

    <div class="mx-auto max-w-5xl pt-[120px] pb-[60px] md:pt-[150px] md:pb-[80px]">
      <div
        class="grid grid-cols-1 gap-0 border-t border-[rgba(212,175,55,0.14)]"
      >
        {
          [
            {
              n: "01",
              k: "360° Growth",
              v: "Cross-platform thinking, end-to-end",
            },
            {
              n: "02",
              k: "Multi-Vertical Revenue",
              v: "Stack of revenue lines by design",
            },
            {
              n: "03",
              k: "Audience Development",
              v: "Community, retention, monetization",
            },
            {
              n: "04",
              k: "Visioneering",
              v: "Strategic brainstorming as a discipline",
            },
          ].map((row, i) => (
            <div
              class={`group flex flex-col items-center gap-2 border-b border-[rgba(212,175,55,0.12)] py-6 text-center transition-colors hover:bg-[rgba(212,175,55,0.03)] reveal reveal-delay-${(i % 4) + 1} md:grid md:grid-cols-12 md:items-center md:gap-4 md:text-left`}
            >
              <span class="text-[0.7rem] uppercase tracking-[0.3em] text-bone-muted md:col-span-1">
                {row.n}
              </span>
              <span class="font-display text-2xl font-light text-bone group-hover:text-gold-gradient md:col-span-5 md:text-3xl">
                {row.k}
              </span>
              <span class="text-[0.82rem] uppercase tracking-[0.18em] text-bone-muted md:col-span-5">
                {row.v}
              </span>
              <span class="hidden text-gold-300 opacity-0 transition-all group-hover:opacity-100 group-hover:translate-x-1 md:col-span-1 md:flex md:justify-end">
                →
              </span>
            </div>
          ))
        }
      </div>
    </div>

  </div>
</section>
