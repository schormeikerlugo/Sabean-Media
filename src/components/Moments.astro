---
import { moments } from "~/data/moments";
import Diamond from "./Diamond.astro";

// Sketch port: ArchiveGrid + ArchiveTile (from sabean-site_1.html)
const items = moments;
---

<section id="moments" class="relative py-32 md:py-48 bg-black overflow-hidden">
  <div class="mt-8 px-6 md:px-14 max-w-7xl mx-auto">
    <div class="flex items-center gap-4 mb-10 reveal">
      <Diamond size={14} class="text-[color:var(--gold)]" stroke={1.2} />
      <span
        class="text-[10px] uppercase tracking-[0.5em] text-[color:var(--gold)]"
        style="font-family: var(--font-mono);"
      >
        Archive · Talent in our orbit
      </span>
      <div class="h-px bg-[color:var(--gold)]/30 flex-1"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-5">
      {items.map((p) => (
        <figure
          class={`relative overflow-hidden bg-neutral-950 group ${p.span === "wide" ? "md:col-span-2 aspect-[8/5]" : "aspect-[4/5]"}`}
        >
          <img
            src={p.image}
            alt={p.name}
            loading="lazy"
            decoding="async"
            class="sk-archive-img absolute inset-0 w-full h-full object-cover"
          />

          <div
            aria-hidden="true"
            class="absolute inset-0 pointer-events-none"
            style="background: linear-gradient(180deg, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.25) 45%, rgba(0,0,0,0.92) 100%);"
          ></div>

          <div
            aria-hidden="true"
            class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-[0.35] transition-opacity duration-500"
            style="background: radial-gradient(ellipse at center, rgba(212,175,75,0.35), transparent 70%); mix-blend-mode: overlay;"
          ></div>

          <div
            aria-hidden="true"
            class="absolute inset-2 border border-[rgba(212,175,75,0.2)] group-hover:border-[rgba(212,175,75,0.8)] pointer-events-none z-10 transition-colors duration-500"
          ></div>

          <Diamond size={8} stroke={1.4} class="absolute z-10 opacity-80 text-[color:var(--gold)] top-[6px] left-[6px]" />
          <Diamond size={8} stroke={1.4} class="absolute z-10 opacity-80 text-[color:var(--gold)] top-[6px] right-[6px]" />
          <Diamond size={8} stroke={1.4} class="absolute z-10 opacity-80 text-[color:var(--gold)] bottom-[6px] right-[6px]" />
          <Diamond size={8} stroke={1.4} class="absolute z-10 opacity-80 text-[color:var(--gold)] bottom-[6px] left-[6px]" />

          <figcaption class="absolute bottom-0 left-0 right-0 p-4 md:p-5 z-10">
            <div
              class="text-[8px] md:text-[9px] uppercase tracking-[0.4em] text-[color:var(--gold)] mb-1"
              style="font-family: var(--font-mono);"
            >
              {p.caption}
            </div>
            <div
              class="text-lg md:text-2xl text-[color:var(--ivory)] leading-tight"
              style="font-family: var(--font-display-sketch);"
            >
              {p.name}
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
