---
import { moments } from "~/data/moments";

const hero = moments[0];
const rest = moments.slice(1, 9);
---

<section id="moments" class="relative overflow-hidden bg-ink py-28 md:py-36">
  <div class="mx-auto max-w-[1600px] px-6 md:px-10">
    <header class="mb-16 grid grid-cols-1 items-end gap-10 md:grid-cols-12">
      <div class="md:col-span-6 reveal">
        <div class="flex items-center gap-3 text-[0.7rem] uppercase tracking-[0.32em] text-bone-muted">
          <span class="text-bone">Big Moments.</span>
          <span class="text-gold-400">(*)</span>
        </div>
        <h2 class="mt-6 font-display text-[clamp(2.8rem,5.2vw,4.5rem)] font-light leading-[0.95]">
          Real culture
          <span class="block italic text-shine">for real talent.</span>
        </h2>
      </div>

      <div class="md:col-span-6 md:pl-10 md:border-l md:border-[rgba(212,175,55,0.12)] reveal reveal-delay-1">
        <p class="max-w-lg text-[0.95rem] leading-relaxed text-bone/75 md:text-right md:ml-auto">
          Selected moments that highlight the team's approach — personality-driven content, partnerships and platforms that earn attention and compound revenue.
        </p>
      </div>
    </header>

    <div class="relative">
      <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-1/2 -z-0 -translate-y-1/2 select-none">
        <div class="whitespace-nowrap text-center font-display text-[clamp(5rem,18vw,20rem)] font-light leading-[0.85] text-bone/[0.04] tracking-[-0.04em]">
          PREVIOUS <span class="italic text-gold-gradient/10" style="opacity:0.06">PROJECTS</span>
        </div>
      </div>

      <div class="relative z-10 mx-auto flex max-w-3xl flex-col items-center gap-6 px-4 py-16 md:py-24 reveal">
        <figure class="group relative aspect-[4/5] w-full max-w-md overflow-hidden rounded-2xl border border-[rgba(212,175,55,0.18)] bg-black ring-1 ring-[rgba(212,175,55,0.08)] shadow-[0_40px_120px_-20px_rgba(212,175,55,0.25)]">
          <img
            src={hero.image}
            alt={hero.title}
            loading="eager"
            decoding="async"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1400ms] ease-out group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <p class="text-[0.6rem] uppercase tracking-[0.28em] text-gold-300">{hero.subtitle}</p>
            <p class="mt-1 font-display text-xl text-bone">{hero.title}</p>
          </div>
        </figure>

        <div class="flex flex-col items-center gap-2">
          <span class="text-[0.68rem] uppercase tracking-[0.32em] text-gold-400">* Featured Moment</span>
          <p class="max-w-sm text-center text-sm leading-relaxed text-bone/70">
            A sample from the catalog — cultural firsts with Chris Rock, Joan Rivers, Kate Hudson, Opie &amp; Anthony, Ron White and more.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-8 grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
      {rest.map((m, i) => (
        <figure class={`group relative aspect-[3/4] overflow-hidden rounded-xl border border-[rgba(212,175,55,0.1)] bg-[#0a0a0a] reveal reveal-delay-${(i % 6) + 1}`}>
          <img
            src={m.image}
            alt={m.title}
            loading="lazy"
            decoding="async"
            class="absolute inset-0 h-full w-full object-cover grayscale-[40%] transition-all duration-[1200ms] group-hover:scale-[1.08] group-hover:grayscale-0"
          />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black via-black/30 to-transparent"></div>
          <figcaption class="absolute inset-x-0 bottom-0 translate-y-1 p-4 transition-transform duration-500 group-hover:translate-y-0">
            <p class="text-[0.58rem] uppercase tracking-[0.28em] text-gold-300">{m.subtitle}</p>
            <p class="mt-1 text-sm font-light text-bone">{m.title}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
