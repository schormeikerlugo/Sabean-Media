---
const rows = [
  { n: "(01)", brand: "The Howard Stern Channels", platform: "SiriusXM", category: "Channel Launch & Leadership", year: "2006" },
  { n: "(02)", brand: "Head of Podcasts", platform: "Westwood One", category: "Podcast Strategy & Slate", year: "2018" },
  { n: "(03)", brand: "SVP, Programming", platform: "CBS Radio", category: "National Programming", year: "2015" },
  { n: "(04)", brand: "Comedy Central Radio", platform: "SiriusXM / Viacom", category: "Channel Development", year: "2012" },
  { n: "(05)", brand: "UnMasked Town Halls", platform: "SiriusXM", category: "Live / Interview Format", year: "2010" },
  { n: "(06)", brand: "Ignite Creator Studios", platform: "Sabean Media", category: "Creator Platform", year: "2024" },
];
---

<section id="recognition" class="relative overflow-hidden bg-ink-soft py-28 md:py-36">
  <div class="mx-auto max-w-[1600px] px-6 md:px-10">
    <header class="mb-14 flex flex-col items-start justify-between gap-4 md:flex-row md:items-end reveal">
      <div class="flex items-center gap-3 text-[0.7rem] uppercase tracking-[0.32em] text-bone-muted">
        <span class="text-bone">Recognition.</span>
        <span class="text-gold-400">(*)</span>
      </div>
      <p class="max-w-md text-sm leading-relaxed text-bone/70">
        A snapshot of the brands, platforms and roles the team has led or launched across three decades in media.
      </p>
    </header>

    <div class="relative overflow-hidden rounded-2xl border border-[rgba(212,175,55,0.18)] bg-[#0a0a0a]">
      <div class="hidden grid-cols-12 gap-4 border-b border-[rgba(212,175,55,0.14)] px-6 py-4 text-[0.62rem] uppercase tracking-[0.32em] text-bone-muted md:grid md:px-10">
        <span class="col-span-1">No.</span>
        <span class="col-span-4">Brand / Role</span>
        <span class="col-span-3">Platform</span>
        <span class="col-span-3">Category</span>
        <span class="col-span-1 text-right">Year</span>
      </div>

      <ul>
        {rows.map((r, i) => (
          <li class={`group grid grid-cols-12 items-center gap-4 px-6 py-5 transition-colors border-b border-[rgba(212,175,55,0.08)] last:border-0 hover:bg-[rgba(212,175,55,0.04)] md:px-10 md:py-6 reveal reveal-delay-${(i % 6) + 1}`}>
            <span class="col-span-2 text-[0.62rem] uppercase tracking-[0.32em] text-bone-muted md:col-span-1">
              {r.n}
            </span>
            <span class="col-span-10 font-display text-lg font-light text-bone transition-colors group-hover:text-gold-gradient md:col-span-4 md:text-xl">
              {r.brand}
            </span>
            <span class="col-span-6 col-start-3 text-[0.78rem] uppercase tracking-[0.18em] text-bone-muted md:col-span-3 md:col-start-auto">
              <span class="md:hidden text-[0.6rem] tracking-[0.28em] text-gold-400 mr-2">Platform</span>
              {r.platform}
            </span>
            <span class="col-span-6 text-[0.78rem] uppercase tracking-[0.18em] text-bone-muted md:col-span-3">
              <span class="md:hidden text-[0.6rem] tracking-[0.28em] text-gold-400 mr-2">Category</span>
              {r.category}
            </span>
            <span class="col-span-12 text-[0.78rem] uppercase tracking-[0.18em] text-gold-300 md:col-span-1 md:text-right">
              {r.year}
            </span>
          </li>
        ))}
      </ul>

      <div class="flex items-center justify-between gap-4 border-t border-[rgba(212,175,55,0.14)] px-6 py-4 text-[0.62rem] uppercase tracking-[0.32em] text-bone-muted md:px-10">
        <span>Recognition</span>
        <span class="font-display text-sm text-gold-gradient">sabean<sup class="ml-0.5 text-[0.6em]">®</sup></span>
        <span>© 2026</span>
      </div>
    </div>
  </div>
</section>
