---
const links = [
  { n: "01", href: "#mission", label: "Mission" },
  { n: "02", href: "#services", label: "Services" },
  { n: "03", href: "#dna", label: "Brands" },
  { n: "04", href: "#moments", label: "Archive" },
  { n: "05", href: "#team", label: "Team" },
];
---

<header
  data-nav
  class="fixed inset-x-0 top-0 z-50 transition-all duration-500 data-[scrolled=true]:bg-black/70 data-[scrolled=true]:backdrop-blur-xl data-[scrolled=true]:border-b data-[scrolled=true]:border-[rgba(212,175,55,0.12)]"
>
  <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-[rgba(212,175,55,0.35)] to-transparent opacity-0 transition-opacity duration-500 group-data-[scrolled=true]/nav:opacity-100"></div>

  <div class="mx-auto grid w-full max-w-[1600px] grid-cols-12 items-center gap-4 px-6 py-4 md:px-10 md:py-5">
    <a
      href="#top"
      class="group col-span-6 flex items-center md:col-span-3"
      aria-label="The Sabean Group — Home"
    >
      <img
        src="/images/logos/sabean-group.png"
        alt="The Sabean Group"
        width="1600"
        height="700"
        decoding="async"
        class="block h-9 w-auto md:h-11 transition-[transform,filter] duration-500 group-hover:scale-[1.03] drop-shadow-[0_2px_10px_rgba(212,175,75,0.25)]"
      />
    </a>

    <nav aria-label="Primary" class="col-span-6 hidden md:block">
      <ul class="flex items-center justify-center gap-7">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="group/link relative flex items-baseline gap-2 py-1 text-[0.68rem] uppercase tracking-[0.26em] text-bone-muted transition-colors hover:text-bone"
            >
              <span class="text-[0.58rem] text-gold-400/70 transition-colors group-hover/link:text-gold-300">({l.n})</span>
              <span class="relative">
                {l.label}
                <span class="absolute -bottom-1 left-0 h-px w-0 bg-gold-300 transition-all duration-500 group-hover/link:w-full"></span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="col-span-6 hidden items-center justify-end gap-4 md:col-span-3 md:flex">
      <div class="hidden flex-col items-end leading-tight lg:flex">
        <span class="text-[0.58rem] uppercase tracking-[0.32em] text-gold-400">Available</span>
        <span class="text-[0.58rem] uppercase tracking-[0.32em] text-bone-muted">
          <span id="nav-clock" class="text-bone">--:--</span>
          <span class="ml-1">EST</span>
        </span>
      </div>
      <a href="#contact" class="btn-gold !py-2.5 !px-5 !text-[0.62rem]">
        Start
        <svg viewBox="0 0 20 20" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10h12M10 4l6 6-6 6"/></svg>
      </a>
    </div>

    <button
      data-nav-toggle
      class="col-span-6 col-start-7 ml-auto grid h-10 w-10 place-items-center rounded-full border border-[rgba(212,175,55,0.35)] bg-black/40 text-bone backdrop-blur-md transition-colors hover:border-[rgba(212,175,55,0.8)] hover:text-gold-200 md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <span class="pointer-events-none flex flex-col items-end gap-1.5">
        <span class="block h-px w-5 bg-current transition-transform"></span>
        <span class="block h-px w-3 bg-current transition-transform"></span>
      </span>
    </button>
  </div>

  <div
    id="mobile-menu"
    data-nav-menu
    data-open="false"
    class="md:hidden overflow-hidden border-t border-[rgba(212,175,55,0.1)] bg-black/95 backdrop-blur-xl transition-all duration-500 data-[open=false]:max-h-0 data-[open=false]:opacity-0 data-[open=true]:max-h-[120vh] data-[open=true]:opacity-100"
  >
    <ul class="flex flex-col px-6 py-4">
      {links.map((l) => (
        <li class="border-b border-[rgba(212,175,55,0.08)] last:border-0">
          <a
            href={l.href}
            class="group flex items-baseline justify-between py-5 text-bone-muted transition-colors hover:text-gold-200"
          >
            <span class="flex items-baseline gap-4">
              <span class="text-[0.58rem] uppercase tracking-[0.3em] text-gold-400">({l.n})</span>
              <span class="font-display text-2xl font-light text-bone group-hover:text-gold-gradient">{l.label}</span>
            </span>
            <span class="text-gold-300 transition-transform group-hover:translate-x-1">→</span>
          </a>
        </li>
      ))}
    </ul>
    <div class="flex flex-col gap-3 border-t border-[rgba(212,175,55,0.1)] px-6 py-6">
      <a href="#contact" class="btn-gold justify-center">
        Start a Conversation
        <svg viewBox="0 0 20 20" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10h12M10 4l6 6-6 6"/></svg>
      </a>
      <a href="mailto:TimSabean@me.com" class="btn-link self-start">Write to Tim</a>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const el = document.getElementById("nav-clock");
    if (!el) return;
    const tick = () => {
      const d = new Date();
      const h = ((d.getUTCHours() - 5 + 24) % 24).toString().padStart(2, "0");
      const m = d.getUTCMinutes().toString().padStart(2, "0");
      el.textContent = `${h}:${m}`;
    };
    tick();
    setInterval(tick, 30000);
  })();
</script>
