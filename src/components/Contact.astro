---
---

<section id="contact" class="relative overflow-hidden bg-ink pt-28 pb-14 md:pt-36 md:pb-20">
  <div aria-hidden="true" class="pointer-events-none absolute left-1/2 top-0 -z-10 h-[600px] w-[600px] -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(212,175,55,0.12)_0%,transparent_60%)] blur-3xl"></div>

  <div class="mx-auto max-w-[1600px] px-6 md:px-10">
    <div class="mb-14 flex items-center justify-between text-[0.62rem] uppercase tracking-[0.32em] text-bone-muted reveal">
      <span>Contact</span>
      <span class="font-display text-sm text-gold-gradient">sabean<sup class="ml-0.5 text-[0.6em]">®</sup></span>
      <span>© 2026</span>
    </div>

    <div class="grid grid-cols-1 gap-14 md:grid-cols-12 md:gap-10">
      <div class="md:col-span-5 reveal">
        <h2 class="font-display text-[clamp(4rem,12vw,11rem)] font-light leading-[0.85] tracking-[-0.04em]">
          Let's
          <span class="block italic text-shine">Talk.</span>
        </h2>

        <div class="mt-10 max-w-sm">
          <div class="flex items-center gap-3 text-[0.72rem] uppercase tracking-[0.28em] text-gold-400">
            <span class="text-gold-400">(*)</span>
            <span class="text-bone">Tell us your needs</span>
          </div>
          <p class="mt-3 text-[0.88rem] leading-relaxed text-bone/70">
            From content strategy and podcast roadmaps to brand and platform development — share what you're building and we'll take it from there.
          </p>
        </div>

        <div class="mt-12 max-w-sm space-y-5 text-sm">
          <p class="text-[0.68rem] uppercase tracking-[0.28em] text-bone-muted">Direct contact</p>
          <div class="flex flex-col gap-5">
            <a href="mailto:TimSabean@me.com" class="group flex flex-col gap-1 border-b border-[rgba(212,175,55,0.18)] pb-3 hover:border-[rgba(212,175,55,0.45)]">
              <span class="text-[0.6rem] uppercase tracking-[0.3em] text-gold-400">Tim Sabean — Founder</span>
              <span class="flex items-center justify-between text-bone transition-colors group-hover:text-gold-200">
                TimSabean@me.com
                <span class="text-gold-300 transition-transform group-hover:translate-x-1">→</span>
              </span>
              <span class="text-[0.7rem] uppercase tracking-[0.22em] text-bone-muted">+1 646-812-3300</span>
            </a>
            <a href="mailto:GilEdwards@outlook.com" class="group flex flex-col gap-1 border-b border-[rgba(212,175,55,0.18)] pb-3 hover:border-[rgba(212,175,55,0.45)]">
              <span class="text-[0.6rem] uppercase tracking-[0.3em] text-gold-400">Gil Edwards — Partner</span>
              <span class="flex items-center justify-between text-bone transition-colors group-hover:text-gold-200">
                GilEdwards@outlook.com
                <span class="text-gold-300 transition-transform group-hover:translate-x-1">→</span>
              </span>
              <span class="text-[0.7rem] uppercase tracking-[0.22em] text-bone-muted">+1 267-254-6991</span>
            </a>
          </div>
        </div>
      </div>

      <form
        action="mailto:TimSabean@me.com"
        method="post"
        enctype="text/plain"
        class="md:col-span-7 reveal reveal-delay-1"
      >
        <div class="rounded-2xl border border-[rgba(212,175,55,0.18)] bg-[#0a0a0a] p-8 md:p-10">
          <div class="grid grid-cols-1 gap-x-8 gap-y-8 md:grid-cols-2">
            <label class="flex flex-col gap-2">
              <span class="text-[0.62rem] uppercase tracking-[0.3em] text-bone-muted">First Name</span>
              <input required type="text" name="firstname" placeholder="Jane" class="w-full border-b border-[rgba(212,175,55,0.22)] bg-transparent py-2 text-bone placeholder:text-bone-muted/50 outline-none transition-colors focus:border-gold-300" />
            </label>
            <label class="flex flex-col gap-2">
              <span class="text-[0.62rem] uppercase tracking-[0.3em] text-bone-muted">Last Name</span>
              <input type="text" name="lastname" placeholder="Doe" class="w-full border-b border-[rgba(212,175,55,0.22)] bg-transparent py-2 text-bone placeholder:text-bone-muted/50 outline-none transition-colors focus:border-gold-300" />
            </label>
            <label class="flex flex-col gap-2 md:col-span-2">
              <span class="text-[0.62rem] uppercase tracking-[0.3em] text-bone-muted">Email</span>
              <input required type="email" name="email" placeholder="you@brand.com" class="w-full border-b border-[rgba(212,175,55,0.22)] bg-transparent py-2 text-bone placeholder:text-bone-muted/50 outline-none transition-colors focus:border-gold-300" />
            </label>
            <label class="flex flex-col gap-2 md:col-span-2">
              <span class="text-[0.62rem] uppercase tracking-[0.3em] text-bone-muted">Service of interest</span>
              <select name="interest" class="w-full appearance-none border-b border-[rgba(212,175,55,0.22)] bg-transparent py-2 text-bone outline-none transition-colors focus:border-gold-300">
                <option class="bg-ink" value="Content Strategy">Content Strategy</option>
                <option class="bg-ink" value="Product Strategy">Product Strategy</option>
                <option class="bg-ink" value="Brand Strategy">Brand Strategy</option>
                <option class="bg-ink" value="Podcast Roadmap">Podcast Roadmap</option>
                <option class="bg-ink" value="Platform Development">Platform Development</option>
                <option class="bg-ink" value="Business Consulting">Business Consulting</option>
              </select>
            </label>
            <label class="flex flex-col gap-2 md:col-span-2">
              <span class="text-[0.62rem] uppercase tracking-[0.3em] text-bone-muted">Type your message here</span>
              <textarea required name="message" rows="5" placeholder="What are you trying to build?" class="w-full resize-none border-b border-[rgba(212,175,55,0.22)] bg-transparent py-2 text-bone placeholder:text-bone-muted/50 outline-none transition-colors focus:border-gold-300"></textarea>
            </label>
          </div>

          <div class="mt-8 flex items-center justify-end">
            <button type="submit" class="btn-gold">
              Submit
              <svg viewBox="0 0 20 20" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10h12M10 4l6 6-6 6"/></svg>
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>
