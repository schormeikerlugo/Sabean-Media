---
import { brands } from "~/data/brands";

const row = [...brands, ...brands];
---

<section id="dna" class="relative overflow-hidden border-t border-b border-[rgba(212,175,55,0.14)] bg-ink py-20 md:py-24">
  <div class="mx-auto mb-10 flex max-w-[1600px] items-center justify-between px-6 md:px-10">
    <div class="flex items-center gap-3 text-[0.7rem] uppercase tracking-[0.32em] text-bone-muted">
      <span class="text-bone">Our DNA.</span>
      <span class="text-gold-400">(*)</span>
    </div>
    <p class="hidden max-w-md text-right text-[0.8rem] uppercase tracking-[0.2em] text-bone-muted md:block">
      Brands the team has built, launched or scaled
    </p>
  </div>

  <div class="marquee-wrapper relative mask-fade-right">
    <div class="marquee py-4">
      {row.map((b) => (
        <div class="flex h-20 min-w-[200px] items-center justify-center px-8">
          <img
            src={b.logo}
            alt={`${b.name} logo`}
            loading="lazy"
            decoding="async"
            class="max-h-12 w-auto max-w-[180px] object-contain opacity-55 brightness-[1.3] grayscale transition-all duration-700 hover:opacity-100 hover:grayscale-0 hover:brightness-100 hover:scale-110"
          />
        </div>
      ))}
    </div>
  </div>
</section>
