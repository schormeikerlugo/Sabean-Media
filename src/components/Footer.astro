---
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-ink pb-0 pt-0">
  <div class="mx-auto max-w-[1600px] px-6 md:px-10">
    <div class="grid grid-cols-1 items-center gap-8 border-t border-[rgba(212,175,55,0.2)] py-8 md:grid-cols-3">
      <a href="mailto:TimSabean@me.com" class="btn-link">Write to Email</a>

      <a href="tel:+16468123300" class="group flex flex-col items-center text-center">
        <span class="font-display text-2xl font-light text-bone transition-colors group-hover:text-gold-gradient md:text-3xl">(646) 812-3300</span>
        <span class="mt-1 text-[0.6rem] uppercase tracking-[0.32em] text-bone-muted">TimSabean@me.com</span>
      </a>

      <a href="https://wa.me/16468123300" class="btn-link ml-auto">Write to WA</a>
    </div>

    <div class="grid grid-cols-1 gap-8 border-t border-[rgba(212,175,55,0.12)] py-8 text-[0.72rem] uppercase tracking-[0.24em] text-bone-muted md:grid-cols-3">
      <div>
        <p class="text-bone">© {year} The Sabean Group, LLC</p>
        <p class="mt-1">All rights reserved</p>
      </div>
      <div class="md:text-center">
        <p class="text-gold-400">Address:</p>
        <p class="mt-1 text-bone">New York, NY · Remote US</p>
      </div>
      <div class="md:text-right">
        <p>The site has been developed for</p>
        <p class="mt-1 text-bone">Sabean Media · The Sabean Group</p>
      </div>
    </div>

    <div class="pointer-events-none pt-6 pb-2 select-none">
      <p class="font-display font-light leading-[0.78] tracking-[-0.055em] text-[clamp(5rem,27vw,24rem)]">
        <span class="text-gold-gradient">sabean</span><sup class="ml-2 align-super font-sans text-[0.15em] text-gold-300">®</sup>
      </p>
    </div>
  </div>
</footer>
