---
// Hero — logo centered, asymmetric side content pushed to lower third.

const navItems = [
  { n: "(01)", label: "Content & Brand Strategy" },
  { n: "(02)", label: "Podcast & Platform Development" },
  { n: "(03)", label: "Product & Revenue Growth" },
];
---

<section
  id="top"
  class="relative isolate min-h-[100svh] w-full overflow-hidden bg-ink text-bone"
>
  <div class="absolute inset-0 -z-10">
    <video
      class="h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/images/hero-poster.jpg"
      aria-hidden="true"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <div
      class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.78)_0%,rgba(0,0,0,0.72)_30%,rgba(0,0,0,0.82)_65%,#000_100%)]"
    ></div>
    <div
      class="absolute inset-x-0 bottom-0 h-[55%] bg-linear-to-t from-black via-black/80 to-transparent"
    ></div>
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(212,175,55,0.14)_0%,transparent_65%)]"
    ></div>
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_20%_90%,rgba(212,175,55,0.07),transparent_55%)]"
    ></div>
  </div>

  <div
    class="relative z-10 mx-auto flex min-h-[100svh] w-full max-w-[1600px] flex-col px-6 pt-28 pb-8 md:px-10 md:pt-32"
  >
    <!-- Upper spacer: small, keeps logo in the upper third -->
    <div class="grow-[0.55]"></div>

    <!-- Centered logo with subtle halo -->
    <div class="relative flex items-center justify-center">
      <div
        class="pointer-events-none absolute inset-0 -z-10 flex items-center justify-center"
      >
        <div
          class="relative h-[46vw] max-h-[620px] w-[46vw] max-w-[620px]"
        >
          <div
            class="absolute inset-0 rounded-full bg-[radial-gradient(circle,rgba(212,175,55,0.28)_0%,rgba(212,175,55,0.08)_40%,transparent_70%)] blur-2xl float"
          ></div>
          <div
            class="absolute inset-[12%] rounded-full border border-[rgba(212,175,55,0.22)]"
          ></div>
          <div
            class="absolute inset-[26%] rounded-full border border-[rgba(212,175,55,0.14)]"
          ></div>
          <div
            class="absolute inset-[40%] rounded-full border border-[rgba(212,175,55,0.08)]"
          ></div>
        </div>
      </div>

      <h1 class="sr-only">The Sabean Group</h1>
      <div class="reveal pointer-events-none relative">
        <img
          src="/images/logos/sabean-group.png"
          alt="The Sabean Group"
          width="1600"
          height="700"
          decoding="async"
          fetchpriority="high"
          class="mx-auto block w-full max-w-[clamp(17.6rem,65.6vw,57.6rem)] drop-shadow-[0_8px_40px_rgba(212,175,75,0.22)]"
        />
      </div>
    </div>

    <!-- Tight gap: side content sits just below logo, near the hero midline -->
    <div class="h-[3vh] md:h-[5vh]"></div>

    <!-- Side content row: aside (left) + status/nav (right) -->
    <div
      class="reveal reveal-delay-2 grid grid-cols-1 items-start gap-y-10 md:grid-cols-12 md:gap-x-10"
    >
      <aside class="md:col-span-4 text-center md:text-left">
        <p
          class="text-[0.66rem] uppercase tracking-[0.32em] text-bone-muted leading-[1.7]"
        >
          Build your brand
          <span class="block text-bone/70">with personality-</span>
          <span class="block text-bone/70">driven content.</span>
        </p>
        <p
          class="mx-auto md:mx-0 mt-6 max-w-[20rem] text-[0.7rem] uppercase tracking-[0.22em] text-bone-muted leading-[1.9]"
        >
          <span class="text-gold-300">We help high-end talent scale</span> with
          strategy, platforms &amp; partnerships that compound across every vertical.
        </p>
      </aside>

      <div class="hidden md:col-span-4 md:block"></div>

      <div class="md:col-span-4 flex flex-col items-center gap-5 text-center md:items-stretch md:text-left">
        <div
          class="flex flex-wrap items-center justify-center gap-3 text-[0.62rem] uppercase tracking-[0.32em] text-bone-muted md:justify-end"
        >
          <span
            class="flex items-center gap-2 rounded-full border border-[rgba(212,175,55,0.28)] bg-black/40 px-3 py-1.5 backdrop-blur-md"
          >
            <span class="relative flex h-1.5 w-1.5">
              <span
                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-gold-300 opacity-75"
              ></span>
              <span
                class="relative inline-flex h-1.5 w-1.5 rounded-full bg-gold-300"
              ></span>
            </span>
            <span class="text-gold-200">Available for new engagements</span>
          </span>
          <span class="inline-flex items-baseline gap-2">
            <span class="text-bone-muted">EST.</span>
            <span class="text-bone">2024</span>
            <span class="text-bone-muted">· NYC</span>
          </span>
        </div>

        <ol class="flex w-full flex-col gap-0">
          {
            navItems.map((item, i) => (
              <li
                class={`group flex items-baseline justify-center gap-4 py-3 text-[0.78rem] uppercase tracking-[0.22em] text-bone/80 hover:text-gold-200 transition-colors md:justify-start ${i !== 0 ? "border-t border-[rgba(212,175,55,0.12)]" : ""}`}
              >
                <span class="text-bone-muted">{item.n}</span>
                <a href="#services" class="md:flex-1">
                  {item.label}
                </a>
                <span class="opacity-0 transition-all group-hover:opacity-100 text-gold-300">
                  →
                </span>
              </li>
            ))
          }
        </ol>
      </div>
    </div>

    <!-- Lower grow spacer (larger) — leaves breathing room before bottom utility -->
    <div class="grow-[1.6]"></div>

    <!-- Bottom utility row -->
    <div
      class="flex flex-col items-center gap-6 border-t border-[rgba(212,175,55,0.14)] pt-6 text-center md:flex-row md:items-center md:justify-between md:text-left"
    >
      <div class="flex flex-col items-center gap-4 md:flex-row md:gap-6">
        <a
          href="#mission"
          class="btn-circle group"
          aria-label="Scroll to Mission"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-4 w-4 rotate-45 transition-transform duration-500 group-hover:rotate-[135deg]"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M7 7 L17 17 M7 17 L7 7 L17 7"></path></svg
          >
        </a>
        <p
          class="max-w-xs text-[0.66rem] uppercase tracking-[0.22em] text-bone-muted leading-[1.8]"
        >
          <span class="text-gold-300">Content.</span>
          <span class="text-gold-300">Creator.</span>
          <span class="text-gold-300">Brand.</span>
          <span class="text-gold-300">Platform.</span>
          <br />
          Strategy that moves culture.
        </p>
      </div>

      <div class="flex items-center justify-center gap-2 md:justify-end">
        <span
          class="font-display text-[clamp(0.9rem,1.4vw,1.1rem)] uppercase tracking-[0.32em] text-bone-muted"
          >© 2026 — Sabean<sup class="text-[0.7em] ml-0.5 text-gold-300"
            >®</sup
          ></span
        >
      </div>
    </div>
  </div>
</section>
