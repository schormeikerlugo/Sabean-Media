import Moments from "~/components/Moments.astro";
import Team from "~/components/Team.astro";
import Contact from "~/components/Contact.astro";
import Footer from "~/components/Footer.astro";
---

<BaseLayout>
  <Nav />
  <main id="main" class="relative">
    <Hero />
    <Stats />
    <Mission />
    <Services />
    <DNA />
    <Moments />
    <Team />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
